# Core
COMPOSE_PROJECT_NAME=snowflake-telco-lab
DBT_TARGET=snowflake
LOG_LEVEL=INFO

# Local service ports
# Local-only is the secure default. Set LAB_BIND_ADDRESS=0.0.0.0 only for an
# intentional shared demo, and rotate the default local passwords first.
LAB_BIND_ADDRESS=127.0.0.1
LOCAL_POSTGRES_PORT=5433
AIRFLOW_WEB_PORT=8085
DBT_DOCS_PORT=8086
JENKINS_WEB_PORT=8081
JENKINS_AGENT_PORT=50000
DBT_RUNNER_UID=1000
DBT_RUNNER_GID=1000

# Airflow metadata database
POSTGRES_USER=airflow
POSTGRES_PASSWORD=airflow
POSTGRES_MULTIPLE_DATABASES=airflow

# Airflow bootstrap
AIRFLOW_UID=50000
AIRFLOW_FERNET_KEY=replace_with_base64_fernet_key
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=change_me

# Jenkins bootstrap
JENKINS_ADMIN_ID=admin
JENKINS_ADMIN_PASSWORD=change_me
JENKINS_URL=http://localhost:8081/
JENKINS_EXECUTORS=2

# Snowflake connection
SNOWFLAKE_ACCOUNT=your-account
SNOWFLAKE_USER=your-user
SNOWFLAKE_PASSWORD=
SNOWFLAKE_PRIVATE_KEY_PATH=
SNOWFLAKE_PRIVATE_KEY_PASSPHRASE=
SNOWFLAKE_OAUTH_TOKEN=
SNOWFLAKE_AUTHENTICATOR=
SNOWFLAKE_WAREHOUSE=your-authorized-warehouse
SNOWFLAKE_DATABASE=TELCO_LAB
SNOWFLAKE_ROLE=your-authorized-role

# Snowflake repo schemas and load objects
SNOWFLAKE_STAGE_SCHEMA=TELCO_STAGE_LOAD
SNOWFLAKE_DBT_SCHEMA=TELCO_STAGE_DBT
SNOWFLAKE_GOVERNANCE_SCHEMA=TELCO_GOVERNANCE
SNOWFLAKE_FLUID_SCHEMA=TELCO_FLUID_DEMO
SNOWFLAKE_INTERNAL_STAGE=TELCO_SEED_STAGE
SNOWFLAKE_FILE_FORMAT=TELCO_SEED_CSV

# Optional feature toggles
SNOWFLAKE_ENABLE_DMF=false
SNOWFLAKE_ENABLE_CLASSIFICATION=false

# FLUID tracks
FLUID_DEFAULT_TRACK=dev-source
FLUID_DEV_SOURCE_REPO=../forge-cli
FLUID_DEMO_PACKAGE_SPEC=data-product-forge
FLUID_DEFAULT_CONTRACT_SCHEMA_VERSION=0.7.2
FLUID_RUNTIME_ENV_FILE=runtime/generated/fluid.local.env
FLUID_REPORT_DIR=fluid/reports
FLUID_GENERATED_DIR=fluid/generated
FLUID_TESTPYPI_SIMPLE_URL=https://test.pypi.org/simple/
FLUID_PYPI_FALLBACK_URL=https://pypi.org/simple/
# Demo GitLab workspaces are bootstrapped inside the lab repo at ./gitlab/
# via `task workspaces:bootstrap` (gitignored; recreated from tracked templates
# under fluid/fixtures/workspaces/). Leave these blank to use the docker-compose
# defaults; set them only if you have moved the workspaces elsewhere.
FLUID_DEMO_GITLAB_WORKSPACE=
FLUID_AI_GITLAB_WORKSPACE=

# Hosted GitLab placeholders for future contract versioning and CI
GITLAB_PROJECT_URL=
GITLAB_PROJECT_PATH=
GITLAB_TRIGGER_TOKEN=

# Data Mesh Manager placeholders for future FLUID publication work
DMM_API_URL=http://localhost:8095
DMM_API_KEY=

# Seed generation controls
TELCO_SEED_RANDOM_SEED=42
TELCO_SEED_PARTY_COUNT=200
TELCO_SEED_USAGE_EVENT_COUNT=10000
TELCO_SEED_APP_EVENT_COUNT=2000
TELCO_SEED_HISTORY_DAYS=60
