CATALOGS_COMPOSE_PROJECT=snowflake-telco-catalogs
# Keep the demo reproducible. Move this pin only after the catalog smoke test passes.
ENTROPY_IMAGE_TAG=2.0.1
LAB_BIND_ADDRESS=127.0.0.1
ENTROPY_WEB_PORT=8095
ENTROPY_EXTERNAL_URL=http://localhost:8095
ENTROPY_DB_NAME=entropy_data
ENTROPY_DB_USER=entropy
ENTROPY_DB_PASSWORD=change_me
ENTROPY_SUPERADMINS=admin@example.com
ENTROPY_BOOTSTRAP_ADMIN_EMAIL=admin@example.com
ENTROPY_BOOTSTRAP_ADMIN_PASSWORD=change_me
ENTROPY_BOOTSTRAP_ORG_NAME=Telco Demo Org
ENTROPY_BOOTSTRAP_ORG_VANITY_URL=telcodemo
ENTROPY_BOOTSTRAP_API_KEY_NAME=Local DMM Key
ENTROPY_MAIL_FROM=Entropy Data <noreply@snowflake-telco-lab.local>
ENTROPY_DATACONTRACT_SPECIFICATIONS=odcs
ENTROPY_DATAPRODUCT_SPECIFICATIONTYPES=odps
ENTROPY_COMPROMISEDPASSWORDCHECKER_ENABLED=false
# Mailpit replaced the stale MailHog image, but these env names stay for
# backward compatibility with existing launchpads and local .env.catalogs files.
MAILHOG_UI_PORT=8026
MAILHOG_SMTP_PORT=1026
DMM_API_URL=http://localhost:8095
DMM_API_KEY=
