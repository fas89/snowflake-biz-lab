# Copy values you want Jenkins to inherit into .env or pass them at runtime.
JENKINS_ADMIN_ID=admin
JENKINS_ADMIN_PASSWORD=change_me
JENKINS_URL=http://localhost:8081/
JENKINS_EXECUTORS=2

# Snowflake credentials are intentionally read from the same env vars as local tools.
SNOWFLAKE_ACCOUNT=your-account
SNOWFLAKE_USER=your-user
SNOWFLAKE_PASSWORD=
SNOWFLAKE_PRIVATE_KEY_PATH=
SNOWFLAKE_PRIVATE_KEY_PASSPHRASE=
SNOWFLAKE_OAUTH_TOKEN=
SNOWFLAKE_AUTHENTICATOR=
SNOWFLAKE_WAREHOUSE=TELCO_TRANSFORM_WH
SNOWFLAKE_DATABASE=TELCO_LAB
SNOWFLAKE_ROLE=TRANSFORMER
SNOWFLAKE_STAGE_SCHEMA=TELCO_STAGE_LOAD
SNOWFLAKE_DBT_SCHEMA=TELCO_STAGE_DBT
SNOWFLAKE_GOVERNANCE_SCHEMA=TELCO_GOVERNANCE

# Optional Data Mesh Manager placeholders for future catalog publication work.
DMM_API_URL=http://localhost:8095
DMM_API_KEY=
