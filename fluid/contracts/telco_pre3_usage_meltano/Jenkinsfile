// pre-3 (telco_pre3_usage_meltano) — runs the FLUID 11-stage pipeline against
// the Meltano-acquisition contract. fluid apply (stage 7) invokes the forge-cli
// meltano build runner (tap-postgres → target-snowflake), which moves usage
// event, customer interaction, and trouble ticket tables from the telco_source
// Postgres database into the Snowflake bronze stage schema.
//
// Pre-condition: telco_source.telco.{usage_event, customer_interaction,
// trouble_ticket} must be loaded before triggering this job. Run
// `task seed:postgres:load` on the host first.

pipeline {
  agent any

  options {
    disableConcurrentBuilds()
    buildDiscarder(logRotator(numToKeepStr: '20'))
  }

  parameters {
    string(
      name: 'FLUID_ENV',
      defaultValue: 'dev',
      description: 'Environment overlay (dev / staging / prod). Destructive apply modes require --allow-data-loss in non-dev.'
    )
    string(
      name: 'APPLY_MODE',
      defaultValue: 'amend',
      description: 'fluid apply mode: dry-run | create-only | amend | amend-and-build | replace | replace-and-build.'
    )
    string(
      name: 'PUBLISH_TARGETS',
      defaultValue: 'datamesh-manager',
      description: 'Space-separated stage-10 publish targets.'
    )
  }

  environment {
    CONTRACT = 'fluid/contracts/telco_pre3_usage_meltano/contract.fluid.yaml'
    PRE_SCENARIO = 'pre-3'
    PRE_ENGINE = 'meltano'
    // Container-canonical venv at /opt/fluid-venv (set up in
    // deploy/docker/jenkins/Dockerfile). Overlay with bind-mounted
    // dev-source forge-cli at /forge-cli-src so unreleased changes flow
    // through. See pre-1 Jenkinsfile rationale comment.
    FLUID = '/opt/fluid-venv/bin/fluid'
  }

  stages {
    stage('0 — Bootstrap FLUID') {
      steps {
        sh '''
          set -eu
          cd /workspace
          # Copy-then-install dev-source (read-only mount, see pre-1
          # Jenkinsfile rationale).
          if [ -d /forge-cli-src ]; then
            mkdir -p /tmp/forge-cli-build
            rsync -a --delete \
              --exclude='.git' --exclude='.venv*' --exclude='__pycache__' \
              --exclude='.pytest_cache' --exclude='*.egg-info' \
              --exclude='build' --exclude='dist' --exclude='node_modules' \
              /forge-cli-src/ /tmp/forge-cli-build/
            /opt/fluid-venv/bin/pip install --quiet --force-reinstall --no-deps /tmp/forge-cli-build \
              || echo "warn: dev-source install failed; using PyPI forge-cli" >&2
          fi
          # Meltano scenario also needs the Singer tap + target binaries.
          /opt/fluid-venv/bin/pip install --quiet meltanolabs-tap-postgres meltanolabs-target-snowflake \
            || echo "warn: Singer tap/target install failed; meltano build will fail at discovery" >&2
          test -x "$FLUID" && "$FLUID" version || {
            echo "FLUID venv at $FLUID not bootstrapped" >&2
            exit 1
          }
        '''
      }
    }

    stage('1-4 — bundle / validate / generate artifacts / validate-artifacts') {
      steps {
        sh '''
          set -eu
          cd /workspace
          mkdir -p runtime/artifacts
          "$FLUID" bundle "$CONTRACT" --format tgz --out runtime/bundle.tgz
          "$FLUID" validate runtime/bundle.tgz
          "$FLUID" generate artifacts "$CONTRACT" --out runtime/artifacts/
          "$FLUID" validate-artifacts runtime/artifacts/
        '''
      }
    }

    stage('5-6 — diff / plan') {
      steps {
        sh '''
          set -eu
          cd /workspace
          "$FLUID" diff "$CONTRACT" --exit-on-drift --env "$FLUID_ENV"
          "$FLUID" plan "$CONTRACT" --out runtime/plan.json --html
        '''
      }
    }

    stage('7 — apply (acquisition: meltano → Postgres → Snowflake)') {
      steps {
        sh '''
          set -eu
          cd /workspace
          "$FLUID" apply runtime/plan.json \
            --mode "$APPLY_MODE" --env "$FLUID_ENV" --yes \
            --report runtime/apply_report.html
        '''
      }
    }

    stage('8 — policy-apply (self-gated)') {
      steps {
        sh '''
          set -eu
          cd /workspace
          if [ -f runtime/artifacts/policy/bindings.json ]; then
            "$FLUID" policy-apply runtime/artifacts/policy/bindings.json \
              --mode enforce --env "$FLUID_ENV"
          else
            echo "no policy bindings.json — skipping"
          fi
        '''
      }
    }

    stage('9 — verify (DQ rules against the rows Meltano just landed)') {
      steps {
        sh '''
          set -eu
          cd /workspace
          "$FLUID" verify "$CONTRACT" --strict --env "$FLUID_ENV" --out runtime/verify.json
        '''
      }
    }

    stage('10 — publish (DMM)') {
      steps {
        sh '''
          set -eu
          cd /workspace
          TARGET_FLAGS=""
          for t in $PUBLISH_TARGETS; do TARGET_FLAGS="$TARGET_FLAGS --target $t"; done
          "$FLUID" publish "$CONTRACT" $TARGET_FLAGS --env "$FLUID_ENV"
        '''
      }
    }

    stage('11 — schedule-sync (no-op for SDP)') {
      steps {
        echo 'schedule-sync skipped — SDP contracts have no DAG to register'
      }
    }
  }

  post {
    always {
      archiveArtifacts artifacts: 'runtime/**/*,fluid/contracts/telco_pre3_usage_meltano/runtime/**/*', allowEmptyArchive: true
    }
  }
}
