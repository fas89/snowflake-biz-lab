// pre-1 (telco_pre1_billing_dlt) — runs the FLUID 11-stage pipeline against
// the dlt-acquisition contract. fluid apply (stage 7) invokes the forge-cli
// dlt build runner natively, which moves data from the telco_source Postgres
// database into the Snowflake bronze stage schema.
//
// Pre-condition: telco_source.telco.{invoice, invoice_charge} must be loaded
// before triggering this job. Run `task seed:postgres:load` on the host first.

pipeline {
  agent any

  options {
    disableConcurrentBuilds()
    buildDiscarder(logRotator(numToKeepStr: '20'))
  }

  parameters {
    string(
      name: 'FLUID_ENV',
      defaultValue: 'dev',
      description: 'Environment overlay (dev / staging / prod). Destructive apply modes require --allow-data-loss in non-dev.'
    )
    string(
      name: 'APPLY_MODE',
      defaultValue: 'amend',
      description: 'fluid apply mode: dry-run | create-only | amend | amend-and-build | replace | replace-and-build.'
    )
    string(
      name: 'PUBLISH_TARGETS',
      defaultValue: 'datamesh-manager',
      description: 'Space-separated stage-10 publish targets.'
    )
  }

  environment {
    CONTRACT = 'fluid/contracts/telco_pre1_billing_dlt/contract.fluid.yaml'
    PRE_SCENARIO = 'pre-1'
    PRE_ENGINE = 'dlt'
    // Inside the lab Jenkins container (deploy/docker/jenkins/Dockerfile),
    // /opt/fluid-venv is the canonical Python venv. The dev-source
    // forge-cli is bind-mounted read-only at /forge-cli-src so we can
    // ``pip install -e`` it as an overlay. The host's .venv.fluid-dev is
    // also visible at /workspace/.venv.fluid-dev but its bin/ scripts
    // pin host-only Python paths in their shebangs and won't run inside
    // the container — don't use it.
    FLUID = '/opt/fluid-venv/bin/fluid'
  }

  stages {
    stage('0 — Bootstrap FLUID') {
      steps {
        sh '''
          set -eu
          cd /workspace
          # Overlay the bind-mounted dev-source forge-cli onto the
          # container venv so unreleased changes flow through Jenkins
          # builds. /forge-cli-src is bind-mounted READ-ONLY but pip's
          # build backend needs to write ``*.egg-info`` next to setup.py
          # (even for non-editable installs — the build_wheel step
          # generates metadata inline). Copy to a writable location each
          # build, then install from there. ``rsync --exclude``-style
          # filtering keeps the copy small (skips .git, .venv*, runtime
          # caches). When the bind-mount is missing (Jenkins outside the
          # lab container), fall back to PyPI.
          if [ -d /forge-cli-src ]; then
            # cp instead of rsync (rsync not in the Jenkins base image).
            # Skip .git + venvs + caches via find+cpio pipe — keeps the
            # copy small and avoids hitting the read-only fs's symlinks.
            rm -rf /tmp/forge-cli-build
            mkdir -p /tmp/forge-cli-build
            (cd /forge-cli-src && find . \
              -path './.git' -prune -o \
              -path './.venv*' -prune -o \
              -name '__pycache__' -prune -o \
              -name '.pytest_cache' -prune -o \
              -name '*.egg-info' -prune -o \
              -name 'build' -prune -o \
              -name 'dist' -prune -o \
              -name 'node_modules' -prune -o \
              -type f -print | cpio -pdmu /tmp/forge-cli-build/ 2>/dev/null)
            /opt/fluid-venv/bin/pip install --quiet --force-reinstall --no-deps /tmp/forge-cli-build \
              || echo "warn: dev-source install failed; using PyPI forge-cli" >&2
          fi
          test -x "$FLUID" && "$FLUID" version || {
            echo "FLUID venv at $FLUID not bootstrapped" >&2
            exit 1
          }
        '''
      }
    }

    stage('1-4 — bundle / validate / generate artifacts / validate-artifacts') {
      steps {
        sh '''
          set -eu
          cd /workspace
          mkdir -p runtime/artifacts
          "$FLUID" bundle "$CONTRACT" --format tgz --out runtime/bundle.tgz
          "$FLUID" validate runtime/bundle.tgz
          "$FLUID" generate artifacts "$CONTRACT" --out runtime/artifacts/
          "$FLUID" validate-artifacts runtime/artifacts/
        '''
      }
    }

    stage('5-6 — diff / plan') {
      steps {
        sh '''
          set -eu
          cd /workspace
          "$FLUID" diff "$CONTRACT" --exit-on-drift --env "$FLUID_ENV"
          "$FLUID" plan "$CONTRACT" --out runtime/plan.json --html
        '''
      }
    }

    stage('7 — apply (acquisition: dlt → Postgres → Snowflake)') {
      steps {
        sh '''
          set -eu
          cd /workspace
          "$FLUID" apply runtime/plan.json \
            --mode "$APPLY_MODE" --env "$FLUID_ENV" --yes \
            --report runtime/apply_report.html
        '''
      }
    }

    stage('8 — policy-apply (self-gated)') {
      steps {
        sh '''
          set -eu
          cd /workspace
          if [ -f runtime/artifacts/policy/bindings.json ]; then
            "$FLUID" policy-apply runtime/artifacts/policy/bindings.json \
              --mode enforce --env "$FLUID_ENV"
          else
            echo "no policy bindings.json — skipping"
          fi
        '''
      }
    }

    stage('9 — verify (DQ rules against the rows dlt just landed)') {
      steps {
        sh '''
          set -eu
          cd /workspace
          "$FLUID" verify "$CONTRACT" --strict --env "$FLUID_ENV" --out runtime/verify.json
        '''
      }
    }

    stage('10 — publish (DMM)') {
      steps {
        sh '''
          set -eu
          cd /workspace
          TARGET_FLAGS=""
          for t in $PUBLISH_TARGETS; do TARGET_FLAGS="$TARGET_FLAGS --target $t"; done
          "$FLUID" publish "$CONTRACT" $TARGET_FLAGS --env "$FLUID_ENV"
        '''
      }
    }

    stage('11 — schedule-sync (no-op for SDP)') {
      steps {
        echo 'schedule-sync skipped — SDP contracts have no DAG to register'
      }
    }
  }

  post {
    always {
      archiveArtifacts artifacts: 'runtime/**/*,fluid/contracts/telco_pre1_billing_dlt/runtime/**/*', allowEmptyArchive: true
    }
  }
}
